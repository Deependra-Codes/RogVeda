# Use the same env names locally, in GitHub Actions, and in Vercel.
# For local Supabase, fetch the URL + keys from `pnpm dlx supabase status`.
# For hosted deployment, replace the URL + keys with your hosted Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-for-older-projects
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-for-server-writes
ROGVEDA_SESSION_SECRET=replace-with-a-long-random-app-signing-secret
